rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function hasRole(role) {
      return isSignedIn() && role in userDoc().data.roles;
    }

    function hasAnyRole(roles) {
      return isSignedIn() && userDoc().data.roles.hasAny(roles);
    }

    function isAdmin() {
      return hasRole('System Administrator');
    }

    function isVolunteerLeader() {
      return hasRole('Volunteer Leader');
    }

    function isReportingOfficer() {
      return hasRole('Reporting Officer');
    }

    function isDutyOrShiftOfficer() {
      return hasAnyRole(['Duty Officer', 'Shift Officer']);
    }

    function isActiveUser() {
      return isSignedIn() && userDoc().data.status == 'Active';
    }

    match /users/{userId} {
      allow read: if isActiveUser();
      allow create, update, delete: if isAdmin();
    }

    match /volunteers/{volunteerId} {
      allow read: if isActiveUser();
      allow create, update, delete: if isAdmin() || isVolunteerLeader();
    }

    match /checklistTemplates/{templateId} {
      allow read: if isActiveUser();
      allow create, update, delete: if isAdmin();

      match /items/{itemId} {
        allow read: if isActiveUser();
        allow create, update, delete: if isAdmin();
      }
    }

    match /shifts/{shiftId} {
      allow read: if isActiveUser();
      allow create: if isAdmin() || isVolunteerLeader();
      allow update: if isAdmin()
                    || isVolunteerLeader()
                    || isReportingOfficer()
                    || isDutyOrShiftOfficer();
      allow delete: if isAdmin();

      match /shiftVolunteers/{shiftVolunteerId} {
        allow read: if isActiveUser();
        allow create, update: if isAdmin() || isVolunteerLeader() || isReportingOfficer() || isDutyOrShiftOfficer();
        allow delete: if isAdmin();
      }

      match /shiftChecklists/{shiftChecklistId} {
        allow read: if isActiveUser();
        allow create, update: if isAdmin() || isDutyOrShiftOfficer();
        allow delete: if isAdmin();
      }

      match /statusHistory/{statusHistoryId} {
        allow read: if isActiveUser();
        allow create: if isAdmin() || isVolunteerLeader() || isReportingOfficer() || isDutyOrShiftOfficer();
        allow update, delete: if isAdmin();
      }
    }

    match /auditLogs/{auditLogId} {
      allow read: if isAdmin();
      allow create: if isActiveUser();
      allow update, delete: if false;
    }
  }
}
